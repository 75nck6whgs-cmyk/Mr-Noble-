# Copy this file to .env and fill values.

# Required for D-ID API mode
DID_API_KEY=your_d_id_api_key

# Optional: if set, script will use this exact voiceover file instead of TTS.
VOICEOVER_PATH=

# Optional settings
OUTPUT_PATH=output/coco_tree_talking_ugc.mp4
ASPECT_RATIO=9:16
VIDEO_DURATION_SECONDS=10
